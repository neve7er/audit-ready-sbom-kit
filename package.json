{
  "name": "audit-ready",
  "version": "0.1.0-beta.2",
  "description": "Generate CycloneDX 1.5 SBOMs and audit-ready risk triage reports from package-lock.json with rule-based verdicts and VEX output",
  "type": "module",
  "main": "./dist/cli/index.js",
  "bin": {
    "audit-ready": "./bin/audit-ready.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "scan": "node --loader ts-node/esm src/cli/index.ts scan",
    "test": "vitest run"
  },
  "files": [
    "bin/",
    "dist/",
    "schemas/",
    "src/"
  ],
  "keywords": [
    "sbom",
    "cyclonedx",
    "security",
    "audit",
    "vulnerability",
    "vex",
    "sarif",
    "supply-chain"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neve7er/audit-ready-sbom-kit"
  },
  "homepage": "https://github.com/neve7er/audit-ready-sbom-kit#readme",
  "bugs": {
    "url": "https://github.com/neve7er/audit-ready-sbom-kit/issues"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.12.0"
  }
}
